{
  "manifest_version": 3,
  "name": "Brain / Tips / note Reader - 学習アシスト",
  "version": "1.3.2",
  "description": "Brain / Tips / note の長文記事での学習をサポート。目次・栞・ハイライト・メモ・進捗管理・学習カレンダー（3 サイト横断）。サイト自動判定でブランドが切り替わります。",
  "homepage_url": "https://south-create.com/brain-reader/",
  "permissions": ["storage", "clipboardWrite"],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Reader (Brain / Tips / note)",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://brain-market.com/*",
        "https://tips.jp/*",
        "https://note.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
