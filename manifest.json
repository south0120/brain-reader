{
  "manifest_version": 3,
  "name": "Manabi-reader",
  "version": "1.3.2",
  "description": "Manabi-reader：Brain / Tips / note の長文記事を Kindle のように学習する Chrome 拡張",
  "homepage_url": "https://south-create.com/manabi-reader/",
  "permissions": ["storage", "clipboardWrite"],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Manabi-reader",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://brain-market.com/*",
        "https://tips.jp/*",
        "https://note.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
